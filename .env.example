APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Database SIMRS (Sumber Data Pasien & Tindakan)
DB_SIMRS_CONNECTION=mysql
DB_SIMRS_HOST=127.0.0.1
DB_SIMRS_PORT=3306
DB_SIMRS_DATABASE=simrs
DB_SIMRS_USERNAME=root
DB_SIMRS_PASSWORD=
DB_SIMRS_PREFIX=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=terapi_
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE=high
REDIS_QUEUE_RETRY_AFTER=90

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SatuSehat FHIR API
SATUSEHAT_AUTH_URL=https://api-satusehat.kemkes.go.id/oauth2/v1
SATUSEHAT_BASE_URL=https://api-satusehat.kemkes.go.id/fhir-r4/v1
SATUSEHAT_CLIENT_ID=
SATUSEHAT_CLIENT_SECRET=
SATUSEHAT_ORGANIZATION_ID=
SATUSEHAT_TIMEOUT=30
SATUSEHAT_DEBUG=false
SATUSEHAT_API_DELAY_MS=300
SATUSEHAT_RATE_LIMIT_PER_MINUTE=50

# BPJS Kesehatan
VCLAIM_BPJS_URL="https://apijkn-dev.bpjs-kesehatan.go.id/vclaim-rest-dev"
ANTRIAN_ONLINE_BPJS_URL="https://apijkn-dev.bpjs-kesehatan.go.id/antreanrs_dev"
APOTEK_ONLINE_BPJS_URL="https://apijkn-dev.bpjs-kesehatan.go.id/apotek-rest-dev"
ERM_BPJS_URL="https://apijkn-dev.bpjs-kesehatan.go.id/erekammedis_dev"
ICARE_BPJS_URL="https://apijkn-dev.bpjs-kesehatan.go.id/ihs_dev"
CONS_ID_VCLAIM_BPJS=
CONS_ID_ANTRIAN_ONLINE_BPJS=
CONS_ID_APOTEK_ONLINE_BPJS=
CONS_ID_ICARE_BPJS=
CONS_ID_ERM_BPJS=
USER_KEY_VCLAIM_BPJS=
USER_KEY_ANTRIAN_ONLINE_BPJS=
USER_KEY_APOTEK_ONLINE_BPJS=
USER_KEY_ERM_BPJS=
USER_KEY_ICARE_BPJS=
SECRET_KEY_VCLAIM_BPJS=
SECRET_KEY_ANTRIAN_ONLINE_BPJS=
SECRET_KEY_APOTEK_ONLINE_BPJS=
SECRET_KEY_ICARE_BPJS=
SECRET_KEY_ERM_BPJS=
JKN_RS_URL=
JKN_RS_USERNAME=
JKN_RS_PASSWORD=
APLICARE_BPJS_URL=
CONS_ID_APLICARE_BPJS=
SECRET_KEY_APLICARE_BPJS=
USER_KEY_APLICARE_BPJS=
# Pilihan kode kelas Aplicare (pisahkan dengan koma). Kosongkan untuk pakai default.
APLICARE_KODE_KELAS=
KODE_PPK=
KODE_PPK_APOTEK_ONLINE=
KODE_PPK_RS_KEMENKES=

# Informasi Rumah Sakit
HOSPITAL_NAME="Rumah Sakit"
HOSPITAL_ALIAS="RS"
HOSPITAL_PHONE="021-1234567"
HOSPITAL_EMAIL=
HOSPITAL_WEBSITE=
HOSPITAL_ADDRESS="Jalan Rumah Sakit No. 1"
HOSPITAL_CITY="Kota"
HOSPITAL_PROVINCE="Provinsi"
HOSPITAL_POSTAL_CODE="12345"
HOSPITAL_COUNTRY="ID"

# Kode Administratif RS (untuk Satu Sehat — standar Kemendagri)
HOSPITAL_PROPINSI_CODE=
HOSPITAL_KABUPATEN_CODE=
HOSPITAL_KECAMATAN_CODE=
HOSPITAL_KELURAHAN_CODE=

# Antrian Online — kode poli/dokter yang dikecualikan dari pencatatan bpjs_antrian_registrations
ANTROL_EX_POLYCLINICS=
ANTROL_EX_DOCTORS=

# OAuth RS — Single Sign-On (kosongkan untuk menonaktifkan)
OAUTH_RS_URL=
OAUTH_RS_CLIENT_ID=
